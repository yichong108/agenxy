# Copy to one of: `.env`, `.env.development`, or `.env.development.local` (recommended for local secrets).
# See docs/langfuse.md for Langfuse setup. Do not commit files that contain real keys.

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Optional: match your Langfuse Cloud region or self-hosted root URL (omit for EU cloud default).
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# Optional: set to true / 1 / yes to disable tracing even when keys are set.
# LANGFUSE_TRACING_DISABLED=true
