# Copy to one of: `.env`, `.env.development`, or `.env.development.local` (recommended for local secrets).
# See docs/langfuse.md for Langfuse setup. Do not commit files that contain real keys.

# ===============================
# Langfuse 配置
# ===============================

# 模式选择: cloud (云服务) | local (本地自托管)
LANGFUSE_MODE=local

# --- 本地模式配置 (LANGFUSE_MODE=local) ---
# 本地服务默认地址
LANGFUSE_BASE_URL=http://localhost:3000

# 使用本地 Docker Compose 部署时的默认密钥
# 首次启动后，在 Langfuse Web UI 中创建项目并获取以下密钥:
LANGFUSE_SECRET_KEY="sk-lf-377b2143-adf6-42bc-ace8-91070e8b2f6c"
LANGFUSE_PUBLIC_KEY="pk-lf-cf72a098-12f7-4dba-9dda-bffb32879c5a"

# --- 云端模式配置 (LANGFUSE_MODE=cloud) ---
# 如需使用 Langfuse Cloud，取消以下注释并填写密钥:
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# 可选: 其他云端区域
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# 可选: 设为 true / 1 / yes 禁用追踪（即使已配置密钥）
LANGFUSE_TRACING_DISABLED=false

# ===============================
# 本地 Langfuse 服务 Docker 配置
# ===============================
# 以下配置仅在使用 docker-compose.langfuse.yml 部署时需要

# Postgres 配置
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse
POSTGRES_DB=langfuse
POSTGRES_PORT=5432

# Redis 配置
REDIS_PASSWORD=langfuse
REDIS_PORT=6379

# MinIO (S3 对象存储) 配置
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Langfuse Web 服务端口
LANGFUSE_PORT=3000

# Langfuse 安全配置 (生产环境请修改!)
SALT=your-salt-here-min-32-chars-long!!
ENCRYPTION_KEY=your-32-byte-encryption-key-base64==
NEXTAUTH_SECRET=your-nextauth-secret-here

# Langfuse 初始化配置 (可选)
# 设置后将自动创建组织、项目和用户
LANGFUSE_INIT_ORG_ID=local-org
LANGFUSE_INIT_ORG_NAME=Local Organization
LANGFUSE_INIT_PROJECT_ID=local-project
LANGFUSE_INIT_PROJECT_NAME=Local Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-local-project
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-local-project
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=admin

# 遥测设置
TELEMETRY_ENABLED=false
