
# ===============================
# 本地 Langfuse 服务 Docker 配置
# ===============================
# 以下配置仅在使用 docker-compose.langfuse.yml 部署时需要

# Postgres 配置
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse
POSTGRES_DB=langfuse
POSTGRES_PORT=5432

# Redis 配置
REDIS_PASSWORD=langfuse
REDIS_PORT=6379

# MinIO (S3 对象存储) 配置
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Langfuse Web 服务端口
LANGFUSE_PORT=3000

# Langfuse 安全配置 (生产环境请修改!)
SALT=zg0fVobu3fyV16ZKT30Vu95z75gXnBmP
ENCRYPTION_KEY=646ef27eb55d2f636044bb5eebf32a9374030d4c482165326fc2045c69014ed5
NEXTAUTH_SECRET=Ca7pK8rvff7ysDALLi90aMuCVkl0chwI

# Langfuse 初始化配置 (可选)
# 设置后将自动创建组织、项目和用户
LANGFUSE_INIT_ORG_ID=local-org
LANGFUSE_INIT_ORG_NAME=Local Organization
LANGFUSE_INIT_PROJECT_ID=local-project
LANGFUSE_INIT_PROJECT_NAME=Local Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-local-project
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-local-project
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=admin123456

# 遥测设置
TELEMETRY_ENABLED=false
