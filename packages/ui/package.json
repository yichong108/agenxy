{
  "name": "@agenxy/ui",
  "version": "1.0.0",
  "description": "Shared UI components and styles for Agenxy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": {
      "import": "./dist/styles/index.css"
    }
  },
  "scripts": {
    "build": "tsc && npm run build:css",
    "build:css": "sass src/styles:dist/styles --style compressed",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "antd": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.99.0",
    "typescript": "^5.8.3"
  }
}
