#==============================
# 使用说明 / Usage Guide
#==============================
#
# 1. 文件用途:
#    此文件为 Langfuse 本地开发环境的示例环境变量配置文件。
#    配合 docker-compose.yml 使用，用于快速启动本地 Langfuse 服务。
#
# 2. 如何使用:
#    a) 复制此文件为任意 .env 文件:
#       cp .env.example .env.local
#
#    b) 根据需要修改 .env 文件中的配置值（特别是安全相关的密钥）
#
#    c) 启动服务（以下两种方式任选其一）:
#
#       方式1 - 使用 docker-compose 自动加载 .env 文件:
#       只要 .env 文件位于 docker-compose.yml 同目录下，docker-compose 会自动读取
#       docker-compose up -d
#
#       方式2 - 显式指定 env 文件:
#       docker-compose --env-file .env.local up -d
#
# 3. 访问地址:
#    - Langfuse Web 界面: http://localhost:3000
#    - MinIO 控制台: http://localhost:9001
#    - Postgres 端口: 5432 (仅本地访问)
#    - Redis 端口: 6379 (仅本地访问)
#
# 4. 默认登录凭据 (如启用了初始化配置):
#    - 邮箱: admin@example.com
#    - 密码: admin123456
#
# 5. 安全提示:
#    - 生产环境务必修改 SALT、ENCRYPTION_KEY、NEXTAUTH_SECRET
#    - 使用强密码替换默认的数据库密码
#    - 不要将真实的 .env 文件提交到版本控制
#
# 6. 生成随机密钥 (可选):
#    如需生成新的随机密钥替换默认值，可使用以下命令:
#    - NEXTAUTH_SECRET:  openssl rand -base64 32
#    - SALT:             openssl rand -base64 32
#    - ENCRYPTION_KEY:   openssl rand -hex 32
#
# ===============================

# ===============================
# 本地 Langfuse 服务 Docker 配置
# ===============================
# 以下配置仅在使用 docker-compose.yml 部署时需要
# 所有服务仅在本地开发环境使用，请勿直接用于生产环境

# Postgres 配置
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse
POSTGRES_DB=langfuse
POSTGRES_PORT=5432

# Redis 配置
REDIS_PASSWORD=langfuse
REDIS_PORT=6379

# MinIO (S3 对象存储) 配置
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Langfuse Web 服务端口
LANGFUSE_PORT=3000

# Langfuse 安全配置 (生产环境请修改!)
SALT=zg0fVobu3fyV16ZKT30Vu95z75gXnBmP
ENCRYPTION_KEY=646ef27eb55d2f636044bb5eebf32a9374030d4c482165326fc2045c69014ed5
NEXTAUTH_SECRET=Ca7pK8rvff7ysDALLi90aMuCVkl0chwI

# Langfuse 初始化配置 (可选)
# 设置后将自动创建组织、项目和用户
LANGFUSE_INIT_ORG_ID=local-org
LANGFUSE_INIT_ORG_NAME=Local Organization
LANGFUSE_INIT_PROJECT_ID=local-project
LANGFUSE_INIT_PROJECT_NAME=Local Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-local-project
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-local-project
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=admin123456

# 遥测设置
TELEMETRY_ENABLED=false
