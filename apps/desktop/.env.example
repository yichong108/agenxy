# Agenxy Desktop 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值
# .env.local 不会被提交到 git

# ===============================
# Langfuse 追踪配置（可选）
# ===============================
# 用于 LLM 调用追踪和调试，不配置则禁用追踪
# 参考: https://langfuse.com/docs

# Langfuse 服务地址
LANGFUSE_BASE_URL="http://127.0.0.1:3000"

# Langfuse 项目公钥（用于客户端上传追踪数据）
LANGFUSE_PUBLIC_KEY="pk-lf-xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Langfuse 项目私钥（用于服务端验证）
LANGFUSE_SECRET_KEY="sk-lf-xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# 开启 Langfuse 调试日志（开发时可选）
# LANGFUSE_DEBUG=true
